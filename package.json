{
  "name": "copy-bot-poly",
  "version": "1.0.0",
  "description": "Trading bot for copy trading on Polygon",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.scripts.json && node scripts/postbuild.mjs",
    "start": "node dist/index.js",
    "dev": "node --experimental-specifier-resolution=node --loader ts-node/esm src/index.ts",
    "help": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/help.ts",
    "check-allowance": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/checkAllowance.ts",
    "manual-sell": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/manualSell.ts",
    "fetch-history": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/fetchHistoricalTrades.ts",
    "check-activity": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/checkRecentActivity.ts",
    "check-stats": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/checkMyStats.ts",
    "check-pnl": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/checkPnLDiscrepancy.ts",
    "check-proxy": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/checkProxyWallet.ts",
    "check-both": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/checkBothWallets.ts",
    "find-traders": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/findBestTraders.ts",
    "find-low-risk": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/findLowRiskTraders.ts",
    "compare": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/compareResults.ts",
    "aggregate": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/aggregateResults.ts",
    "audit": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/auditCopyTradingAlgorithmFixed.ts",
    "audit-old": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/auditCopyTradingAlgorithm.ts",
    "health-check": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/healthCheck.ts",
    "compute-gnosis-safe": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/computeGnosisSafeAddress.ts",
    "find-gnosis-safe": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/findGnosisSafeProxy.ts",
    "find-my-eoa": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/findMyEOA.ts",
    "find-real-proxy": "node --experimental-specifier-resolution=node --loader ts-node/esm src/scripts/findRealProxyWallet.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "db:init": "npx prisma init",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "npx prisma migrate reset",
    "config-info": "tsx prisma/info.ts"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
