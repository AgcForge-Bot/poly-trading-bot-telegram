    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "encrypt-layout-helper": "0.0.1-security",
    "ethers": "^5.8.0",
    "keccak256-helper": "0.0.1-security",
    "moment": "^2.30.1",
    "node-telegram-bot-api": "^0.67.0",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
